# Copy values into your process environment. SignalForge does not load this file automatically.
SIGNALFORGE_TELEGRAM_API_ID=replace_with_api_id
SIGNALFORGE_TELEGRAM_API_HASH=replace_with_api_hash
SIGNALFORGE_TELEGRAM_SESSION_PATH=/absolute/path/outside/repository/telegram
SIGNALFORGE_TELEGRAM_CHAT=replace_with_chat_username_or_id
SIGNALFORGE_DATABASE_URL=postgresql+psycopg://signalforge:replace_password@localhost/signalforge
